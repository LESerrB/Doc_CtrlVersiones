% -------- BLOQUE DE DATO --------
\newcommand{\hexblock}[2]{
\node[
    draw,
    trapezium,
    trapezium left angle=75,
    trapezium right angle=105,
    minimum height=0.6cm,
    minimum width=0.8cm,
    inner sep=2pt,
    text height=1.5ex,
    text depth=0.25ex,
    align=center
] at (#1,0) {#2};
}

\newcommand{\drawbus}[2]{
\node (start) at (0,0) {};
\node[left] at (start) {#1};

\def\prev{start}

\foreach \val in {#2} {
    \node[
        draw,
        trapezium,
        trapezium left angle=75,
        trapezium right angle=105,
        minimum height=0.6cm,
        inner sep=2pt,
        text height=1.5ex,
        text depth=0.25ex,
        right=0pt of \prev
    ] (block) {\val};
    
    \xdef\prev{block}
}
}

